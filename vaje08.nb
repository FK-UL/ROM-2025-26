Cell[TextData[{
 StyleBox["2.",
  FontWeight->"Bold"],
 " Sestavi naslednje funkcije:\n 1.) ",
 StyleBox["Imena[podatki_]",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 ", ki vrne seznam imen stolpcev (prva vrstica tabele). Uporabi\[SHacek] \
lahko funkcijo \[OpenCurlyQuote]Keys\[CloseCurlyQuote].\n 2.) ",
 StyleBox["Podatki[podatki_]",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 ", ki vrne tabelo podatkov, t.j. podatke v vrsticah brez glave tabele. \
Uporabi\[SHacek] lahko funkcijo \[OpenCurlyQuote]Values\[CloseCurlyQuote].\n \
3.) ",
 StyleBox["IndeksStolpca[podatki_, stolpec_]",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 ", ki za dano ime stolpca vrne indeks stolpca. Npr. pri na\[SHacek]i tabeli \
klic ",
 StyleBox["IndeksStolpca[podatki, \[OpenCurlyDoubleQuote]Ime\
\[CloseCurlyDoubleQuote]]",
  FontSlant->"Italic"],
 " vrne 2. \[CapitalCHacek]e stolpec s tem imenom ne obstaja, naj funkcija \
vrne Null (prazno). Poskusi uporabiti funkcijo \[OpenCurlyQuote]Position\
\[CloseCurlyQuote], za definiranje lokalnih spremenljivk pa lahko uporabi\
\[SHacek] funkcijo \[OpenCurlyQuote]Module\[CloseCurlyQuote].\n 4.) ",
 StyleBox["Stolpec[podatki_, stolpec_]",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 ", ki vrne podatke v stolpcu s podanim imenom stolpec. Seznam naj vsebuje \
samo podatke, ne pa tudi glave. Poskusi uporabiti funkcijo \
\[OpenCurlyQuote]Transpose\[CloseCurlyQuote].\n5.) ",
 StyleBox["PovprecjeTock[podatki_]",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 ", ki izra\[CHacek]una povpre\[CHacek]je dose\[ZHacek]enih to\[CHacek]k. \
Uporabi funkcijo \[OpenCurlyQuote]Mean\[CloseCurlyQuote].\n6.) ",
 StyleBox["RazlicneVrednosti[podatki_, stolpec_]",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 ", ki vrne seznam razli\[CHacek]nih vrednosti za stolpec. Koliko skupin \
testov so pisali? Namig: preveri, kaj naredi funkcija \[OpenCurlyQuote]Union\
\[CloseCurlyQuote] na seznamih, v katerih se ponavaljajo vrednosti.\n7.) ",
 StyleBox["Vrstica[podatki_, i_]",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 ", ki vrne i-to vrstico v tabeli. Pazi: vrstice z glavo ne \[SHacek]teje\
\[SHacek]. Vrstica z indeksom 1 je prva naslednja vrstica po glavi, t.j. prva \
vrstica postdoc."
}], "Text",
 CellChangeTimes->{{3.9851478822495384`*^9, 3.9851478922124395`*^9}, {
   3.9851479305953197`*^9, 3.9851481114960384`*^9}, {3.9851481480911455`*^9, 
   3.985148217838454*^9}, 3.9851482981235075`*^9, {3.985148910902585*^9, 
   3.985148923588157*^9}, {3.9851490390807962`*^9, 3.9851490400741787`*^9}, {
   3.9852395966316543`*^9, 3.9852396010536213`*^9}, {3.985273088321402*^9, 
   3.9852730971018877`*^9}, {3.985273319770336*^9, 3.98527334493591*^9}, {
   3.9852734847379646`*^9, 3.9852735045967245`*^9}, {3.9852736395047626`*^9, 
   3.9852736736838183`*^9}, {3.985324379441408*^9, 3.9853243819538937`*^9}, 
   3.9853266460194397`*^9},ExpressionUUID->"1a769373-e519-485b-b258-\
826671c5a0d2"],

Cell[TextData[{
 StyleBox["3.",
  FontWeight->"Bold"],
 " Sestavi funkcijo ",
 StyleBox["OcenaZaMeje[{za6_, za7_, za8_, za9_, za10_}, tocke_]",
  FontWeight->"Bold"],
 ", pri kateri so v prvem argumentu meje za ocene v \[SHacek]tevilu to\
\[CHacek]k, v drugem argumentu pa \[SHacek]tevilo to\[CHacek]k, za katere\n\
\[ZHacek]elimo izra\[CHacek]unati oceno. Funkcijo napi\[SHacek]i s pomo\
\[CHacek]jo ustreznih stavkov \[OpenCurlyQuote]",
 "If\[CloseCurlyQuote]",
 ". Nato sestavi funkcijo ",
 StyleBox["Ocene[podatki_, meje_]",
  FontWeight->"Bold"],
 ", ki izra\[CHacek]una stolpec ocen za dane podatke in meje."
}], "Text",
 CellChangeTimes->{{3.985239644692469*^9, 
  3.985239784122751*^9}},ExpressionUUID->"fa46e67f-a2c0-400c-9e56-\
76011006aee7"],

Cell[TextData[{
 StyleBox["4.",
  FontWeight->"Bold"],
 " Sestavi funkcijo ",
 StyleBox["DodajStolpec[podatki_]",
  FontWeight->"Bold"],
 ", ki obstoje\[CHacek]i tabeli doda \[SHacek]e en stolpec (oz . vrne novo \
tabelo z dodanim stolpcem) . Premisli, kako s pomo\[CHacek]jo \
\[OpenCurlyQuote]Query\[CloseCurlyQuote] doda\[SHacek] stolpec tabeli.  \
Podatkom dodaj stolpec \"Ocena\" z ocenami in vse skupaj shrani v \
spremenljivko ",
 StyleBox["podatkiOcene",
  FontSlant->"Italic"],
 ". Novo tabelo shrani v Excelov zvezek \[OpenCurlyQuote]ocene.xlsx\
\[CloseCurlyQuote] s pomo\[CHacek]jo ukaza \[OpenCurlyQuote]Export\
\[CloseCurlyQuote] ."
}], "Text",
 CellChangeTimes->{{3.9852397776051655`*^9, 3.9852397800421305`*^9}, {
  3.9852398126988883`*^9, 3.9852399085416565`*^9}, {3.985274011227133*^9, 
  3.985274014265061*^9}, {3.9852745439486957`*^9, 
  3.9852745447927713`*^9}},ExpressionUUID->"ddafbd4d-e66d-4101-964e-\
c054ea633987"],

Cell[TextData[{
 StyleBox["5.",
  FontWeight->"Bold"],
 " Preveri, kaj naredi funkcija \[OpenCurlyQuote]BinCount\[CloseCurlyQuote] \
na seznamu ocen. Ali bi se dele rezultata te funkcije dalo uporabiti, da bi \
pre\[SHacek]teli, koliko \[SHacek]tudentov je dobilo kak\[SHacek]no oceno? \
Namig : uporabi\[SHacek] lahko funkcije za delo s seznami kot so Rest, Drop, \
Take, ... Izra\[CHacek]unaj porazdelitev ocen in jo shrani v spremenljivko \
\[OpenCurlyQuote]porazdelitevOcen\[CloseCurlyQuote]. To je seznam \
\[SHacek]estih vrednosti, pri \[CHacek]emer prva predstavlja \[SHacek]tevilo \
\[SHacek]tudentov z negativno oceno, druga \[SHacek]tevilo \[SHacek]tudentov \
z oceno 6, . . ."
}], "Text",
 CellChangeTimes->{{3.9852399435235586`*^9, 3.9852399714010763`*^9}, {
  3.9852405189352884`*^9, 
  3.985240584166198*^9}},ExpressionUUID->"22b9d7e8-af8a-47ef-94ba-\
cc72a7f9157a"],

